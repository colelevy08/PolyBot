# ── Polymarket CLOB Credentials ──────────────────────────────────────────────
# Your Polymarket private key (hex, no 0x prefix)
POLY_PRIVATE_KEY=

# API key and secret from https://clob.polymarket.com/
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Polygon RPC (used for on-chain queries if needed)
POLYGON_RPC=https://polygon-rpc.com

# ── Trading Parameters ────────────────────────────────────────────────────────
# Bankroll is AUTO-SET from your live Polymarket balance at startup.
# Only set this if you want to override it (e.g., risk only a portion).
# BANKROLL_USDC=500.0

# Kelly fraction (0.25 = quarter Kelly, recommended)
KELLY_FRACTION=0.25

# Max single position size as fraction of bankroll
MAX_POSITION_FRACTION=0.10

# Minimum edge required to copy a trade (e.g., 0.03 = 3%)
MIN_EDGE_THRESHOLD=0.03

# Minimum implied probability for a bet (skip near-certain outcomes)
MIN_PROB=0.05
MAX_PROB=0.95

# ── Analysis Parameters ───────────────────────────────────────────────────────
# Number of wallets to fetch in initial scan
INITIAL_WALLET_COUNT=10000

# Minimum trades for a wallet to be scored
MIN_TRADE_COUNT=50

# How many top whales to track (final target)
TOP_WHALE_COUNT=15

# Path to save whale analysis results
WHALE_DATA_PATH=data/whales.json

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
