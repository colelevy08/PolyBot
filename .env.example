# ── Polymarket CLOB Credentials ──────────────────────────────────────────────
# Your Polymarket private key (hex, no 0x prefix)
POLY_PRIVATE_KEY=

# API key and secret from https://clob.polymarket.com/
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Polygon RPC (used for on-chain queries if needed)
POLYGON_RPC=https://polygon-rpc.com

# ── Trading Parameters ────────────────────────────────────────────────────────
# Bankroll is AUTO-SET from your live Polymarket balance at startup.
# Only set this if you want to override it (e.g., risk only a portion).
# BANKROLL_USDC=500.0

# Hard cap on how much the bot will risk at any time regardless of balance.
MAX_BANKROLL_USDC=1000.0

# Kelly fraction (0.25 = quarter Kelly, recommended)
KELLY_FRACTION=0.25

# Max single position size as fraction of bankroll
MAX_POSITION_FRACTION=0.10

# Minimum edge required to copy a trade (e.g., 0.03 = 3%)
MIN_EDGE_THRESHOLD=0.03

# Minimum implied probability for a bet (skip near-certain outcomes)
MIN_PROB=0.05
MAX_PROB=0.95

# ── Analysis Parameters ───────────────────────────────────────────────────────
# Number of wallets to fetch in initial scan
INITIAL_WALLET_COUNT=10000

# Minimum trades for a wallet to be scored
MIN_TRADE_COUNT=50

# How many top whales to track (final target)
TOP_WHALE_COUNT=15

# Path to save whale analysis results
WHALE_DATA_PATH=data/whales.json

# ── Whale polling ─────────────────────────────────────────────────────────────
# How often to poll each whale's trades for new activity (seconds).
# With 15 whales: 15 / WHALE_POLL_INTERVAL_SEC req/s. Keep below RATE_LIMIT_RPS.
WHALE_POLL_INTERVAL_SEC=2.0

# ── Rate limiting (whale analysis) ────────────────────────────────────────────
# Max requests per second to Polymarket APIs during wallet analysis
RATE_LIMIT_RPS=10.0

# ── Position monitoring ────────────────────────────────────────────────────────
# How often to check open positions for market resolution (seconds)
POSITION_POLL_INTERVAL_SEC=300

# Seconds to wait for order fill before cancelling and unblocking the slot
ORDER_FILL_TIMEOUT_SEC=30

# ── Whale data freshness ───────────────────────────────────────────────────────
# Re-run analysis if whales.json is older than this many hours
WHALE_DATA_MAX_AGE_HOURS=24

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
